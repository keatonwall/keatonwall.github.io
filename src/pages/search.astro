---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search everything on the site.">
  <div class="wrap">
    <header class="head">
      <h1>Search</h1>
      <p class="muted">
        Full text search across every post. You can also narrow by category or
        tag without typing anything.
      </p>
    </header>

    <div class="search">
      {/* faceted + preload lets the filters work as a browse tool with no query */}
      <pagefind-config instance="site" faceted preload excerpt-length="25"
      ></pagefind-config>

      <pagefind-input instance="site" autofocus placeholder="Search posts..."
      ></pagefind-input>

      <div class="filters">
        <pagefind-filter-dropdown instance="site" filter="Category" label="Category"
        ></pagefind-filter-dropdown>
        <pagefind-filter-dropdown instance="site" filter="Tag" label="Tag"
        ></pagefind-filter-dropdown>
      </div>

      <pagefind-summary instance="site" default-message="Browse all posts"
      ></pagefind-summary>

      <pagefind-results instance="site"></pagefind-results>
    </div>

    <noscript>
      <p class="muted">
        Search needs JavaScript. You can still browse by
        <a href="/blog">category</a> or <a href="/tags">tag</a>.
      </p>
    </noscript>
  </div>
</BaseLayout>

<!-- Pagefind generates these into /pagefind at build time (see package.json). -->
<link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
<script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>

<style>
  .head { margin-bottom: var(--space-m); }
  .head h1 { margin-bottom: var(--space-2xs); }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin-block: var(--space-s);
  }

  /* Map Pagefind's component tokens onto the site's design tokens. Because our
     tokens already flip with the theme, search follows light/dark for free. */
  .search {
    --pf-text: var(--fg);
    --pf-text-secondary: var(--fg-muted);
    --pf-text-muted: var(--fg-muted);
    --pf-background: var(--bg);
    --pf-border: var(--border);
    --pf-border-focus: var(--fg-muted);
    --pf-hover: var(--bg-subtle);
    --pf-skeleton: var(--bg-subtle);
    --pf-skeleton-shine: var(--border);
    --pf-mark: var(--fg);
    --pf-outline-focus: var(--accent);

    --pf-font: var(--font-sans);
    --pf-border-radius: 8px;
    --pf-input-height: 44px;
    --pf-input-font-size: 1rem;
    --pf-result-title-font-size: 1.05rem;
    --pf-result-excerpt-font-size: 0.95rem;
    --pf-results-gap: 0;
  }
</style>

<style is:global>
  /* Highlight matches in the site's accent instead of a plain bold. */
  pagefind-results mark {
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    color: inherit;
    border-radius: 2px;
  }
</style>
