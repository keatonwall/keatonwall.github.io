---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="This page could not be found.">
  <section class="wrap center">
    <p class="eyebrow">404</p>
    <h1>This page isn't available.</h1>
    <p class="muted">The link may be broken, or the page may have moved.</p>
    <p><a href="/">← Back home</a></p>
  </section>
</BaseLayout>

<style>
  .center {
    text-align: center;
    padding-block: var(--space-2xl);
    max-width: var(--measure);
  }
  .center h1 { margin-block: var(--space-2xs) var(--space-s); }
</style>
