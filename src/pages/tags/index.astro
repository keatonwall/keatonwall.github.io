---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Count how many posts use each tag, then sort by frequency (then alphabetically).
const counts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0])
);
---

<BaseLayout title="Tags" description="Browse everything by tag.">
  <div class="wrap">
    <header class="head">
      <h1>Tags</h1>
      <p class="muted">
        A more granular way to find things than the categories.
      </p>
    </header>

    {
      tags.length === 0 ? (
        <p class="muted">No tags yet.</p>
      ) : (
        <ul class="cloud">
          {tags.map(([tag, count]) => (
            <li>
              <a href={`/tags/${tag}`}>
                #{tag}
                <span class="count">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>

<style>
  .head { margin-bottom: var(--space-m); }
  .head h1 { margin-bottom: var(--space-2xs); }

  .cloud {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }
  .cloud a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    transition: color 0.15s, border-color 0.15s;
  }
  .cloud a:hover { color: var(--accent); border-color: var(--accent); }
  .count {
    font-size: 0.85em;
    color: var(--fg-muted);
    background: var(--bg-subtle);
    border-radius: 100px;
    padding: 0 0.4rem;
  }
</style>
