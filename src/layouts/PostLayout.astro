---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CategoryBadge from '../components/CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  heroImage?: string;
}
const { title, description, pubDate, updatedDate, category, tags = [], heroImage } =
  Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="wrap">
    <header class="post-header">
      <div class="meta">
        <CategoryBadge category={category} />
        <FormattedDate date={pubDate} />
        {updatedDate && <span class="muted">· updated <FormattedDate date={updatedDate} /></span>}
      </div>
      <h1>{title}</h1>
      <p class="lead muted">{description}</p>
    </header>

    {heroImage && <img class="hero" src={heroImage} alt="" loading="lazy" />}

    <div class="prose">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <footer class="tags">
          {tags.map((t) => <span class="tag">#{t}</span>)}
        </footer>
      )
    }

    <p class="back"><a href="/blog">← All writing</a></p>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: var(--space-l);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--fg-muted);
    margin-bottom: var(--space-s);
  }
  h1 { margin-bottom: var(--space-xs); }
  .lead {
    font-size: var(--step-1);
    line-height: 1.4;
    margin: 0;
  }
  .hero {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin-bottom: var(--space-l);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin-top: var(--space-l);
    padding-top: var(--space-s);
    border-top: 1px solid var(--border);
  }
  .tag {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--fg-muted);
  }
  .back {
    margin-top: var(--space-l);
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }
</style>
